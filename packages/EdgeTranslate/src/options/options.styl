@import '../common/style/input.styl';

html, body {
    width: 100%;
    padding: 0;
    margin: 0;
    background-color: var(--et-bg, #eeeeee);
    color: var(--et-text, #222);
}

#option {
    padding: 0 10%;
    margin: auto;
    max-width: 840px;
    margin: 0px auto;
    box-shadow: 0px 0px 50px var(--et-border, rgb(200, 200, 200, 0.5));
    background-color: var(--et-block-bg, white);
}

header {
    width: 100%;
    height: 25%;
    padding: 5% 0;
    font-size: 64px;
    font-weight: bold;
    color: color-primary;
    display: flex;
    align-items: center;
}

.row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    line-height: 4em;
    margin: 3% 5%;
    flex: 1 1;
}

.column {
    display: flex;
    align-items: center;
    min-width: 30%;
    max-width: 70%;
}

.checked-label {
    cursor: pointer;
    font-size: medium;
    flex: 3 3 50%;
    justify-content: space-between;
}

.radio-label {
    cursor: pointer;
    font-size: medium;
}

.setting-title {
    font-size: large;
    font-weight: bold;
    color: var(--et-text, inherit);
}

.space {
    display: inline-block;
    width: 5px;
}

.api-config-section {
    margin: 3% 5%;
    padding: 15px;
    background: var(--et-block-bg, #f9f9f9);
    border-radius: 8px;
    border: 1px solid var(--et-border, #e0e0e0);
}

.api-config-row {
    display: flex;
    align-items: center;
    margin: 10px 0;
    gap: 10px;
}

.api-config-label {
    min-width: 150px;
    font-size: 14px;
    font-weight: 500;
    color: var(--et-text, #333);
}

.api-key-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid var(--et-border, #ccc);
    border-radius: 6px;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
    background-color: var(--et-input-bg, #fff);
    color: var(--et-text, #333);
}

.api-key-input:focus {
    border-color: color-primary;
    box-shadow: 0 0 0 2px rgba(74, 140, 247, 0.2);
}

.api-config-hint {
    margin-top: 8px;
    font-size: 12px;
    color: var(--et-muted, #888);
}

.api-config-link {
    color: color-primary;
}

.api-config-divider {
    margin: 15px 0;
    border-top: 1px solid var(--et-border, #e0e0e0);
}

.api-config-actions {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.api-btn {
    padding: 6px 16px;
    border: 1px solid var(--et-border, #ccc);
    border-radius: 6px;
    background: var(--et-block-bg, #f5f5f5);
    cursor: pointer;
    font-size: 13px;
    transition: background 0.2s;
    color: var(--et-text, #333);
}

.api-btn:hover {
    background: var(--et-hover-bg, #e0e0e0);
}

.ai-config-entry {
    background: var(--et-block-bg, #fafafa);
    border: 1px solid var(--et-border, #e8e8e8);
    border-radius: 8px;
    padding: 12px;
    margin-bottom: 10px;
}

.ai-config-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.ai-config-index {
    font-size: 12px;
    font-weight: 600;
    color: var(--et-muted, #8c8c8c);
}

.ai-config-remove {
    border: none;
    background: none;
    font-size: 18px;
    color: var(--et-muted, #ccc);
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
}

.ai-config-remove:hover {
    color: #ff4d4f;
}

.api-add-btn {
    width: 100%;
    padding: 8px;
    border: 1px dashed var(--et-border, #d9d9d9);
    border-radius: 6px;
    background: var(--et-block-bg, #fafafa);
    cursor: pointer;
    font-size: 13px;
    color: var(--et-muted, #8c8c8c);
    transition: all 0.2s;
}

.api-add-btn:hover {
    border-color: #667eea;
    color: #667eea;
    background: var(--et-hover-bg, #f0f0ff);
}

header {
    color: var(--et-accent, color-primary);
}

footer {
    padding: 5% 0;
    text-align: center;
    font-size: medium;
    color: var(--et-muted, inherit);
}

footer a {
    color: var(--et-accent, #4a8cf7);
}
